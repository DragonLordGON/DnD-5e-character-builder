<Window x:Class="DndCharacterBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="D&amp;D 5e Master Tool" Height="800" Width="1100" Background="#1E1E1E">
    <Window.Resources>
        <Style x:Key="AuroraListItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3E3E42"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#094771"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <TabControl x:Name="MainModeTab" Background="#1E1E1E" BorderThickness="0">
            <TabItem Header="🛠 CHARACTER BUILDER">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Background="#252526">
                        <TextBlock Text="CREATION STEPS" Foreground="Gray" FontSize="10" Margin="10,10,10,10"/>
                        <Button Content="1. Race" Click="GoToRace_Click" Margin="10,5" Padding="5" Background="#3E3E42" Foreground="White" BorderThickness="0"/>
                        <Button Content="2. Ability Scores" Click="GoToStats_Click" Margin="10,5" Padding="5" Background="#3E3E42" Foreground="White" BorderThickness="0"/>
                        <Separator Margin="10,20" Background="#3F3F46"/>
                        <Button x:Name="FinalizeBtn" Content="FINALIZE" Margin="10,0" Background="#007ACC" Foreground="White" FontWeight="Bold" Height="40" IsEnabled="False"/>
                    </StackPanel>

                    <TabControl Grid.Column="1" x:Name="BuilderTabControl" Background="Transparent" BorderThickness="0">
                        <TabControl.ItemContainerStyle>
                            <Style TargetType="TabItem">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Style>
                        </TabControl.ItemContainerStyle>

                        <TabItem>
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,20">
                                    <TextBlock Text="CHOOSE YOUR RACE" Foreground="White" FontSize="24" FontWeight="Bold"/>
                                    <CheckBox x:Name="HomebrewToggle" Content="Include Homebrew" Foreground="Orange" VerticalAlignment="Center" Margin="30,0" Click="HomebrewToggle_Click"/>
                                </StackPanel>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="320"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <DockPanel Grid.Column="0">
                                        <Border DockPanel.Dock="Top" Background="#4A1515" Padding="8,4">
                                            <TextBlock Text="RACE" Foreground="White" FontWeight="Bold" FontSize="11"/>
                                        </Border>
                                        
                                        <ListBox x:Name="RaceList" 
                                                 SelectionChanged="RaceList_SelectionChanged" 
                                                 MouseDoubleClick="RaceList_MouseDoubleClick"
                                                 Background="#2D2D2D" Foreground="White" BorderThickness="0"
                                                 ItemContainerStyle="{StaticResource AuroraListItem}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid HorizontalAlignment="Stretch">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <TextBlock x:Name="LockCheck" Text="✔️" Foreground="#2ECC71" Margin="0,0,8,0" Visibility="Collapsed"/>
                                                        <TextBlock Text="{Binding Name}" Grid.Column="1" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Source}" Grid.Column="2" Foreground="Gray" FontSize="10" VerticalAlignment="Center" Margin="5,0"/>
                                                        
                                                        <Button x:Name="SmallUnlockBtn" Grid.Column="3" Content="✕" 
                                                                Width="18" Height="18" Background="#444" Foreground="White" 
                                                                FontSize="9" BorderThickness="0" Visibility="Collapsed"
                                                                Click="UnlockRace_Click" Cursor="Hand" Margin="5,0,0,0"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </DockPanel>
                                    
                                    <StackPanel Grid.Column="1" Margin="20,0">
                                        <Border Background="#2D2D30" Padding="15" CornerRadius="4">
                                            <StackPanel>
                                                <TextBlock x:Name="RaceDescription" TextWrapping="Wrap" Foreground="White" FontSize="14" Text="Double-click a race to confirm your selection..."/>

                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <Border Grid.Row="2" BorderBrush="#3F3F46" BorderThickness="0,1,0,0" Margin="0,20,0,0" Padding="0,15,0,0">
                                    <Button x:Name="NextToStatsBtn" Content="Next: Ability Scores →" HorizontalAlignment="Right" Width="200" Height="40" Background="#007ACC" Foreground="White" FontWeight="Bold" IsEnabled="False" Click="GoToStats_Click"/>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem>
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="PointsRemainingLabel" Text="Points Remaining: 27" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>
                                
                                <UniformGrid Grid.Row="1" Columns="3" Rows="2">
                                    <Border BorderBrush="#3F3F46" BorderThickness="1" Margin="5" Background="#2D2D30">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="STRENGTH" HorizontalAlignment="Center" Foreground="Orange" FontWeight="Bold"/>
                                            <TextBlock x:Name="StrValue" Text="8" FontSize="40" HorizontalAlignment="Center" Foreground="White"/>
                                            <TextBlock x:Name="StrMod" Text="-1" HorizontalAlignment="Center" Foreground="Gray"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                                                <Button Content="-" Width="40" Height="30" Click="StatDown_Click" Tag="STR"/>
                                                <Button Content="+" Width="40" Height="30" Click="StatUp_Click" Tag="STR" Margin="10,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border BorderBrush="#3F3F46" BorderThickness="1" Margin="5" Background="#2D2D30">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="DEXTERITY" HorizontalAlignment="Center" Foreground="LightBlue" FontWeight="Bold"/>
                                            <TextBlock x:Name="DexValue" Text="8" FontSize="40" HorizontalAlignment="Center" Foreground="White"/>
                                            <TextBlock x:Name="DexMod" Text="-1" HorizontalAlignment="Center" Foreground="Gray"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                                                <Button Content="-" Width="40" Height="30" Click="StatDown_Click" Tag="DEX"/>
                                                <Button Content="+" Width="40" Height="30" Click="StatUp_Click" Tag="DEX" Margin="10,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border BorderBrush="#3F3F46" BorderThickness="1" Margin="5" Background="#2D2D30">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="CONSTITUTION" HorizontalAlignment="Center" Foreground="LightGreen" FontWeight="Bold"/>
                                            <TextBlock x:Name="ConValue" Text="8" FontSize="40" HorizontalAlignment="Center" Foreground="White"/>
                                            <TextBlock x:Name="ConMod" Text="-1" HorizontalAlignment="Center" Foreground="Gray"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                                                <Button Content="-" Width="40" Height="30" Click="StatDown_Click" Tag="CON"/>
                                                <Button Content="+" Width="40" Height="30" Click="StatUp_Click" Tag="CON" Margin="10,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border BorderBrush="#3F3F46" BorderThickness="1" Margin="5" Background="#2D2D30">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="INTELLIGENCE" HorizontalAlignment="Center" Foreground="Thistle" FontWeight="Bold"/>
                                            <TextBlock x:Name="IntValue" Text="8" FontSize="40" HorizontalAlignment="Center" Foreground="White"/>
                                            <TextBlock x:Name="IntMod" Text="-1" HorizontalAlignment="Center" Foreground="Gray"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                                                <Button Content="-" Width="40" Height="30" Click="StatDown_Click" Tag="INT"/>
                                                <Button Content="+" Width="40" Height="30" Click="StatUp_Click" Tag="INT" Margin="10,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border BorderBrush="#3F3F46" BorderThickness="1" Margin="5" Background="#2D2D30">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="WISDOM" HorizontalAlignment="Center" Foreground="LightYellow" FontWeight="Bold"/>
                                            <TextBlock x:Name="WisValue" Text="8" FontSize="40" HorizontalAlignment="Center" Foreground="White"/>
                                            <TextBlock x:Name="WisMod" Text="-1" HorizontalAlignment="Center" Foreground="Gray"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                                                <Button Content="-" Width="40" Height="30" Click="StatDown_Click" Tag="WIS"/>
                                                <Button Content="+" Width="40" Height="30" Click="StatUp_Click" Tag="WIS" Margin="10,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <Border BorderBrush="#3F3F46" BorderThickness="1" Margin="5" Background="#2D2D30">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="CHARISMA" HorizontalAlignment="Center" Foreground="LightPink" FontWeight="Bold"/>
                                            <TextBlock x:Name="ChaValue" Text="8" FontSize="40" HorizontalAlignment="Center" Foreground="White"/>
                                            <TextBlock x:Name="ChaMod" Text="-1" HorizontalAlignment="Center" Foreground="Gray"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                                                <Button Content="-" Width="40" Height="30" Click="StatDown_Click" Tag="CHA"/>
                                                <Button Content="+" Width="40" Height="30" Click="StatUp_Click" Tag="CHA" Margin="10,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>

            <TabItem Header="⚔️ PLAY MODE">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="80"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                        <DockPanel Margin="20,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="WalletLabel" Text="Gold: 100 gp" Foreground="Gold" FontSize="20" FontWeight="Bold"/>
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Content="Switch EN/FR" Click="LanguageToggle_Click" VerticalAlignment="Center" Padding="10,5"/>
                        </DockPanel>
                    </Border>
                    <Grid Grid.Row="1" Margin="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="5">
                            <TextBlock Text="MARKETPLACE" Foreground="Gold" FontWeight="Bold" Margin="0,0,0,10"/>
                            <ComboBox x:Name="CategoryFilter" SelectionChanged="CategoryFilter_SelectionChanged" Margin="0,0,0,10">
                                <ComboBoxItem Content="All / Tout" IsSelected="True"/>
                                <ComboBoxItem Content="Weapons"/>
                                <ComboBoxItem Content="Armor"/>
                            </ComboBox>
                            <ListBox x:Name="ShopList" Height="400" Background="#2D2D2D" Foreground="White"/>
                            <Button Content="BUY SELECTED" Click="BuyItem_Click" Margin="0,10" Height="40" Background="#007ACC" Foreground="White"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5">
                            <TextBlock Text="INVENTORY" Foreground="#4EC9B0" FontWeight="Bold" Margin="0,0,0,10"/>
                            <ListBox x:Name="InventoryDisplay" Height="450" Background="#2D2D2D" Foreground="White">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="400">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" Foreground="White"/>
                                            <TextBlock Grid.Column="1" Text="{Binding PricePaid, StringFormat='{}{0}gp'}" Foreground="Gray"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>