<Window x:Class="DndCharacterBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aurora Character Builder" Height="850" Width="1200" 
        Background="#121212" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentColor" Color="#007ACC"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BorderColor" Color="#333333"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#AAAAAA"/>

        <Style x:Key="AuroraListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Background="Transparent" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2D2D30"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#094771"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <TabControl x:Name="MainModeTab" Background="Transparent" BorderThickness="0">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.ItemContainerStyle>

            <TabItem>
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="100,0">
                        <TextBlock Text="WELCOME TO AURORA" Foreground="White" FontSize="28" FontWeight="Light" Margin="0,0,0,10"/>
                        <TextBlock Text="Start your adventure by creating a hero or managing your vault." Foreground="Gray" Margin="0,0,0,40"/>
                        
                        <Button Click="NewCharacter_Click" Width="400" Height="120" Background="#1E1E1E" BorderBrush="#333">
                            <StackPanel Orientation="Horizontal" Margin="20,0">
                                <TextBlock Text="+" FontSize="48" Foreground="{StaticResource AccentColor}" VerticalAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center" Margin="20,0,0,0">
                                    <TextBlock Text="NEW CHARACTER" Foreground="White" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="CREATE A HERO FROM SCRATCH" Foreground="Gray" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="YOUR CHARACTER VAULT" Foreground="Gray" FontSize="10" FontWeight="Bold" Margin="0,40,0,10" Opacity="0.6"/>
                        <ListBox x:Name="CharacterVaultList" Background="#181818" BorderBrush="#333" BorderThickness="1" Width="400" Height="250" HorizontalAlignment="Left" ItemContainerStyle="{StaticResource AuroraListItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="👤" FontSize="20" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Race}" Foreground="Gray" FontSize="11"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Level, StringFormat='LVL {0}'}" Foreground="{StaticResource AccentColor}" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem>
                <TabControl Background="Transparent" BorderThickness="0">
                    <TabItem Header="🛠 CHARACTER BUILDER" Padding="20,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="#181818" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
                                <StackPanel Margin="15">
                                    <TextBlock Text="PROGRESSION" Foreground="{StaticResource TextSecondary}" FontSize="10" FontWeight="Bold" Margin="0,0,0,15"/>
                                    <Button Content="1. Race Selection" Click="GoToRace_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Foreground="White" HorizontalContentAlignment="Left" Padding="10"/>
                                    <Button Content="2. Ability Scores" Click="GoToStats_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Foreground="White" HorizontalContentAlignment="Left" Padding="10"/>
                                    <Separator Margin="0,20" Background="{StaticResource BorderColor}"/>
                                    <Button Content="← EXIT TO MENU" Click="BackToMenu_Click" Foreground="Gray" FontSize="10" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                                </StackPanel>
                            </Border>

                            <TabControl Grid.Column="1" x:Name="BuilderTabControl" Background="Transparent" BorderThickness="0">
                                <TabControl.ItemContainerStyle>
                                    <Style TargetType="TabItem"><Setter Property="Visibility" Value="Collapsed"/></Style>
                                </TabControl.ItemContainerStyle>

                                <TabItem>
                                    <Grid Margin="30">
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                        <StackPanel Margin="0,0,0,25">
                                            <TextBlock Text="Choose Your Lineage" Foreground="White" FontSize="32" FontWeight="Light"/>
                                            <CheckBox x:Name="HomebrewToggle" Content="Enable Homebrew Content" Foreground="Orange" Margin="0,10,0,0" Click="HomebrewToggle_Click"/>
                                        </StackPanel>
                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="350"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <ListBox x:Name="RaceList" Background="#252526" Foreground="White" ItemContainerStyle="{StaticResource AuroraListItem}" SelectionChanged="RaceList_SelectionChanged">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Name}" Grid.Column="1" FontSize="14"/>
                                                            <TextBlock Text="{Binding Source}" Grid.Column="2" Foreground="#666" FontSize="10" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                            <Border Grid.Column="1" Margin="20,0,0,0" Background="#1E1E1E" Padding="25" CornerRadius="8">
                                                <TextBlock x:Name="RaceDescription" TextWrapping="Wrap" Foreground="White" FontSize="15" Text="Select a race to see details..."/>
                                            </Border>
                                        </Grid>
                                        <Button x:Name="NextToStatsBtn" Grid.Row="2" Content="Next: Ability Scores →" HorizontalAlignment="Right" Width="220" Height="45" Background="{StaticResource AccentColor}" Foreground="White" FontWeight="Bold" Click="GoToStats_Click" Margin="0,20,0,0"/>
                                    </Grid>
                                </TabItem>

                                <TabItem>
                                    <Grid Margin="30">
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                        <Border Background="#252526" Padding="20" Margin="0,0,0,20" CornerRadius="4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="PointsRemainingLabel" Text="27" Foreground="{StaticResource AccentColor}" FontSize="36" FontWeight="Bold"/>
                                                <TextBlock Text="POINTS REMAINING" Foreground="White" VerticalAlignment="Center" Margin="15,0,0,0" FontSize="14" Opacity="0.7"/>
                                            </StackPanel>
                                        </Border>
                                        <UniformGrid Grid.Row="1" Columns="3" Rows="2">
                                            <Border Style="{StaticResource StatCard}"><StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="STRENGTH" HorizontalAlignment="Center" Foreground="Orange" FontSize="11" FontWeight="Bold"/>
                                                <TextBlock x:Name="StrValue" Text="8" FontSize="42" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                                                <TextBlock x:Name="StrMod" Text="-1" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                                    <Button Content="-" Width="40" Height="30" Click="StatDown_Click" Tag="STR"/>
                                                    <Button Content="+" Width="40" Height="30" Click="StatUp_Click" Tag="STR" Margin="5,0,0,0"/>
                                                </StackPanel></StackPanel></Border>
                                            <Border Style="{StaticResource StatCard}"><StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="DEXTERITY" HorizontalAlignment="Center" Foreground="SkyBlue" FontSize="11" FontWeight="Bold"/>
                                                <TextBlock x:Name="DexValue" Text="8" FontSize="42" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                                                <TextBlock x:Name="DexMod" Text="-1" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                                    <Button Content="-" Width="40" Height="30" Click="StatDown_Click" Tag="DEX"/>
                                                    <Button Content="+" Width="40" Height="30" Click="StatUp_Click" Tag="DEX" Margin="5,0,0,0"/>
                                                </StackPanel></StackPanel></Border>
                                            <Border Style="{StaticResource StatCard}"><StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="CONSTITUTION" HorizontalAlignment="Center" Foreground="LightGreen" FontSize="11" FontWeight="Bold"/>
                                                <TextBlock x:Name="ConValue" Text="8" FontSize="42" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                                                <TextBlock x:Name="ConMod" Text="-1" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                                    <Button Content="-" Width="40" Height="30" Click="StatDown_Click" Tag="CON"/>
                                                    <Button Content="+" Width="40" Height="30" Click="StatUp_Click" Tag="CON" Margin="5,0,0,0"/>
                                                </StackPanel></StackPanel></Border>
                                            <Border Style="{StaticResource StatCard}"><StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="INTELLIGENCE" HorizontalAlignment="Center" Foreground="MediumPurple" FontSize="11" FontWeight="Bold"/>
                                                <TextBlock x:Name="IntValue" Text="8" FontSize="42" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                                                <TextBlock x:Name="IntMod" Text="-1" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                                    <Button Content="-" Width="40" Height="30" Click="StatDown_Click" Tag="INT"/>
                                                    <Button Content="+" Width="40" Height="30" Click="StatUp_Click" Tag="INT" Margin="5,0,0,0"/>
                                                </StackPanel></StackPanel></Border>
                                            <Border Style="{StaticResource StatCard}"><StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="WISDOM" HorizontalAlignment="Center" Foreground="Gold" FontSize="11" FontWeight="Bold"/>
                                                <TextBlock x:Name="WisValue" Text="8" FontSize="42" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                                                <TextBlock x:Name="WisMod" Text="-1" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                                    <Button Content="-" Width="40" Height="30" Click="StatDown_Click" Tag="WIS"/>
                                                    <Button Content="+" Width="40" Height="30" Click="StatUp_Click" Tag="WIS" Margin="5,0,0,0"/>
                                                </StackPanel></StackPanel></Border>
                                            <Border Style="{StaticResource StatCard}"><StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="CHARISMA" HorizontalAlignment="Center" Foreground="LightPink" FontSize="11" FontWeight="Bold"/>
                                                <TextBlock x:Name="ChaValue" Text="8" FontSize="42" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                                                <TextBlock x:Name="ChaMod" Text="-1" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                                    <Button Content="-" Width="40" Height="30" Click="StatDown_Click" Tag="CHA"/>
                                                    <Button Content="+" Width="40" Height="30" Click="StatUp_Click" Tag="CHA" Margin="5,0,0,0"/>
                                                </StackPanel></StackPanel></Border>
                                        </UniformGrid>
                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </TabItem>

                    <TabItem Header="⚔️ PLAY MODE" Padding="20,10">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Border Background="#1E1E1E" Padding="20" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="🪙" FontSize="24" Margin="0,0,10,0"/>
                                        <TextBlock x:Name="WalletLabel" Text="100 gp" Foreground="Gold" FontSize="24" FontWeight="Bold"/>
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right" Content="Language: EN/FR" Click="LanguageToggle_Click" Padding="15,8" Background="#333" Foreground="White" BorderThickness="0"/>
                                </DockPanel>
                            </Border>
                            <Grid Grid.Row="1" Margin="20">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Margin="10" Background="#181818" CornerRadius="8" Padding="15">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Text="MARKETPLACE" Foreground="Gold" FontWeight="Bold" Margin="0,0,0,15"/>
                                        <ComboBox x:Name="CategoryFilter" DockPanel.Dock="Top" SelectionChanged="CategoryFilter_SelectionChanged" Margin="0,0,0,10">
                                            <ComboBoxItem Content="All Categories" IsSelected="True"/>
                                        </ComboBox>
                                        <Button DockPanel.Dock="Bottom" Content="PURCHASE ITEM" Click="BuyItem_Click" Height="45" Background="{StaticResource AccentColor}" Foreground="White" Margin="0,15,0,0"/>
                                        <ListBox x:Name="ShopList" Background="Transparent" Foreground="White" BorderThickness="0"/>
                                    </DockPanel>
                                </Border>
                                <Border Grid.Column="1" Margin="10" Background="#181818" CornerRadius="8" Padding="15">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top" Text="YOUR INVENTORY" Foreground="#4EC9B0" FontWeight="Bold" Margin="0,0,0,15"/>
                                        <ListBox x:Name="InventoryDisplay" Background="Transparent" Foreground="White" BorderThickness="0">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#333" BorderThickness="0,0,0,1" Padding="5">
                                                        <Grid>
                                                            <TextBlock Text="{Binding Name}" Foreground="White"/>
                                                            <TextBlock Text="{Binding PricePaid, StringFormat='{}{0} gp'}" HorizontalAlignment="Right" Foreground="#888"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>
        </TabControl>

        <Grid x:Name="OverlayBlur" Visibility="Collapsed" Background="#CC000000">
            <Border Background="#1E1E1E" CornerRadius="12" BorderBrush="#444" BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="480" Padding="30">
                <StackPanel>
                    <TextBlock x:Name="OverlayTitle" Text="NEW HERO" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock x:Name="OverlayMessage" Text="Description" Foreground="#AAA" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,25"/>
                    <TextBox x:Name="OverlayInput" Background="#2D2D30" Foreground="White" BorderBrush="#555" Padding="12" Margin="0,0,0,20" Visibility="Collapsed" FontSize="16"/>
                    
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />     <ColumnDefinition Width="Auto" />  <ColumnDefinition Width="*" />     </Grid.ColumnDefinitions>

                        <Button x:Name="OverlayAltBtn" 
                                Content="SIMPLE" 
                                Click="SimplePreset_Click" 
                                Height="40" Width="110" 
                                Background="#333" Foreground="White" 
                                HorizontalAlignment="Right" Margin="0,0,10,0"
                                Visibility="Collapsed"/>

                        <Button Grid.Column="1" 
                                Content="CANCEL" 
                                Click="CloseOverlay_Click" 
                                Width="80" Height="40" 
                                Background="Transparent" Foreground="#66FFFFFF" 
                                BorderThickness="0"
                                HorizontalAlignment="Center"/>

                        <Button x:Name="OverlayConfirmBtn" 
                                Grid.Column="2"
                                Content="ADVANCED" 
                                Click="ConfirmOverlay_Click" 
                                Width="120" Height="40" 
                                Background="{StaticResource AccentColor}" Foreground="White" 
                                HorizontalAlignment="Left" Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>