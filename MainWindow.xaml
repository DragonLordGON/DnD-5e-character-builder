<Window x:Class="DndCharacterBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="5e Character Builder &amp; Manager" Height="700" Width="1000" Background="#1E1E1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False" Margin="15,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="CHARACTER BUILDER" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Separator Width="20" Visibility="Hidden"/>
                    <CheckBox x:Name="HomebrewToggle" Content="Allow Homebrew" Foreground="Orange" 
                              VerticalAlignment="Center" Click="HomebrewToggle_Click" Margin="10,0"/>
                    <Button Content="Switch EN/FR" Click="LanguageToggle_Click" Padding="10,2" Margin="10,0"/>
                </StackPanel>
                
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="WalletLabel" Text="Gold: 100 gp" Foreground="Gold" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl Grid.Row="1" Background="#1E1E1E" BorderThickness="0" Foreground="White">
            
            <TabItem Header="1. Race">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <ListBox x:Name="RaceList" SelectionChanged="RaceList_SelectionChanged" 
                             Background="#2D2D2D" Foreground="White" BorderThickness="1" BorderBrush="#3F3F46"/>
                    
                    <Border Grid.Column="1" Margin="20,0,0,0" Padding="15" Background="#252526" CornerRadius="5">
                        <ScrollViewer>
                            <StackPanel>
                                <TextBlock Text="Race Details" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" Foreground="#007ACC"/>
                                <TextBlock x:Name="RaceDescription" Text="Select a race from the list to see details..." 
                                           Foreground="White" TextWrapping="Wrap" FontSize="14" LineHeight="20"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="2. Class">
                <Grid Margin="20">
                    <TextBlock Text="Class selection logic based on PHB rules coming soon..." Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </TabItem>

            <TabItem Header="Shop &amp; Inventory">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/> <ColumnDefinition Width="*"/> </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Marketplace" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="Gold"/>
                        <ListBox x:Name="ShopList" Height="450" Background="#2D2D2D" Foreground="White" BorderBrush="#3F3F46"/>
                        <Button Content="Buy Selected Item (Ask DM for Price)" Click="BuyItem_Click" 
                                Margin="0,10" Height="35" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Your Backpack" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" Foreground="#4EC9B0"/>
                        <ListBox x:Name="InventoryDisplay" Height="500" Background="#2D2D2D" Foreground="White" BorderBrush="#3F3F46">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#3F3F46" BorderThickness="0,0,0,1" Padding="5">
                                        <Grid Width="400">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding PricePaid, StringFormat='Paid: {0} gp'}" 
                                                       Foreground="Gray" Margin="10,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" 
                                                Text="{Binding PricePaid, StringFormat='{}Paid: {0} gp'}" 
                                                Foreground="Gray" Margin="10,0" VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2" 
                                                Text="{Binding Weight, StringFormat='{}{0} lbs'}" 
                                                Foreground="#9CDCFE" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>