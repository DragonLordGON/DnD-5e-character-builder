<Window x:Class="DndCharacterBuilder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nebula Character Builder" Height="850" Width="1200" 
        Background="#121212" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <SolidColorBrush x:Key="AccentColor" Color="#007ACC"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BorderColor" Color="#333333"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#AAAAAA"/>

        <Style x:Key="AuroraListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Background="Transparent" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="#2D2D30"/></Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#094771"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatDarkButton" TargetType="Button">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3E3E42"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="20" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" CornerRadius="2" Background="#252526" BorderBrush="#444" BorderThickness="1" />
                <Path x:Name="Arrow" Grid.Column="1" Fill="#999" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="true">
                    <Setter TargetName="Border" Property="Background" Value="#3E3E42" />
                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}" />
                    <Setter TargetName="Arrow" Property="Fill" Value="White" />
                </Trigger>
                <Trigger Property="IsChecked" Value="true">
                    <Setter TargetName="Border" Property="Background" Value="#3E3E42" />
                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}" />
                    <Setter TargetName="Arrow" Property="Fill" Value="White" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="ComboBoxTextBox" TargetType="TextBox">
            <Border x:Name="PART_ContentHost" Focusable="False" Background="{TemplateBinding Background}" />
        </ControlTemplate>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" Template="{StaticResource ComboBoxToggleButton}" Grid.Column="2" Focusable="false" ClickMode="Press" 
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="6,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <TextBox x:Name="PART_EditableTextBox" Style="{x:Null}" Template="{StaticResource ComboBoxTextBox}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,3,23,3" Focusable="True" Background="Transparent" Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#252526" BorderThickness="1" BorderBrush="#444"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                            <Trigger Property="IsGrouping" Value="true">
                                <Setter Property="ScrollViewer.CanContentScroll" Value="false"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
               <Setter.Value>
                 <Style TargetType="ComboBoxItem">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="5"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Border" Background="{TemplateBinding Background}" BorderThickness="0" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="true">
                                        <Setter TargetName="Border" Property="Background" Value="#3E3E42"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                 </Style>
               </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <TabControl x:Name="MainModeTab" Background="Transparent" BorderThickness="0">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem"><Setter Property="Visibility" Value="Collapsed"/></Style>
            </TabControl.ItemContainerStyle>

            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <!-- Main Content Area (Now on Left) -->
                    <Grid Grid.Column="0">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="WELCOME TO NEBULA" Foreground="White" FontSize="36" FontWeight="Light" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                            <TextBlock Text="Start your adventure by creating a hero." Foreground="Gray" Margin="0,0,0,50" HorizontalAlignment="Center" FontSize="16"/>
                            
                            <Button Click="NewCharacter_Click" Width="500" Height="140" Background="#1E1E1E" BorderBrush="#333" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="8">
                                            <ContentPresenter/>
                                            <Border.Triggers>
                                                <EventTrigger RoutedEvent="MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#007ACC" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#333" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Border.Triggers>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <StackPanel Orientation="Horizontal" Margin="40,0" HorizontalAlignment="Center">
                                    <TextBlock Text="+" FontSize="64" Foreground="{StaticResource AccentColor}" VerticalAlignment="Center" FontWeight="Light" Margin="0,-8,0,0"/>
                                    <StackPanel VerticalAlignment="Center" Margin="30,0,0,0">
                                        <TextBlock Text="NEW CHARACTER" Foreground="White" FontWeight="Bold" FontSize="20"/>
                                        <TextBlock Text="CREATE A HERO FROM SCRATCH" Foreground="Gray" FontSize="11" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Vault Sidebar (Now on Right) -->
                    <Border Grid.Column="1" Background="#181818" BorderBrush="{StaticResource BorderColor}" BorderThickness="1,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="20,25,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="CHARACTER VAULT" Foreground="{StaticResource TextSecondary}" FontSize="11" FontWeight="Bold" Opacity="0.8"/>
                                <Button Content="⟳" FontSize="16" Foreground="Gray" Background="Transparent" BorderThickness="0" Margin="0,0,10,0" 
                                        Click="RefreshVault_Click" Grid.Column="1" ToolTip="Refresh List" HorizontalAlignment="Right" Padding="0,-5,0,0"/>
                            </Grid>
                            <ListBox x:Name="CharacterVaultList" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,5,0,0" ItemContainerStyle="{StaticResource AuroraListItem}" MouseDoubleClick="VaultItem_DoubleClick">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="👤" FontSize="20" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="#555"/>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold" FontSize="14"/>
                                                    <TextBlock Text=" (WIP)" Foreground="Orange" FontSize="10" VerticalAlignment="Center" Margin="5,0,0,0" Visibility="{Binding IsWIP, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Race.Name}" Foreground="Gray" FontSize="11"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Level, StringFormat='LVL {0}'}" Foreground="{StaticResource AccentColor}" FontWeight="Bold" FontSize="10" HorizontalAlignment="Right"/>
                                                <Button Content="📂" Width="20" Height="20" Background="Transparent" BorderThickness="0" Foreground="Gray" Click="OpenFolder_Click" Tag="{Binding Name}" ToolTip="Open Save Folder" Margin="0,5,0,0" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="#181818" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
                        <StackPanel Margin="15">
                            <TextBlock Text="PROGRESSION" Foreground="{StaticResource TextSecondary}" FontSize="10" FontWeight="Bold" Margin="0,0,0,15"/>
                            <Button Content="1. Race Selection" Click="GoToRace_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Foreground="White" HorizontalContentAlignment="Left" Padding="10"/>
                            <Button Content="2. Class Selection" Click="GoToClass_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Foreground="White" HorizontalContentAlignment="Left" Padding="10"/>
                            <Button Content="3. Subclass Selection" Click="GoToSubclass_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Foreground="White" HorizontalContentAlignment="Left" Padding="10"/>
                            <Button Content="4. Ability Scores" Click="GoToStats_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Foreground="White" HorizontalContentAlignment="Left" Padding="10"/>
                            <Separator Margin="0,20" Background="{StaticResource BorderColor}"/>
                            <Button Content="← EXIT TO MENU" Click="BackToMenu_Click" Foreground="Gray" FontSize="10" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Global Builder Header -->
                        <Border BorderBrush="#333" BorderThickness="0,0,0,1" Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="💾 SAVE" Click="SaveCharacter_Click" Width="80" Height="30" Background="#333" Foreground="White" BorderThickness="0" FontWeight="Bold" Margin="0,0,20,0"/>
                                </StackPanel>

                                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,20,0" Width="250">
                                    <TextBox x:Name="CharacterNameInput" Height="30" Padding="5" Background="#252526" Foreground="White" BorderBrush="#444" 
                                             TextChanged="CharacterNameInput_TextChanged" LostFocus="CharacterNameInput_LostFocus" GotFocus="CharacterNameInput_GotFocus"
                                             VerticalContentAlignment="Center"/>
                                    <TextBlock x:Name="CharacterNamePlaceholder" Text="Put character name here..." Foreground="Gray" VerticalAlignment="Center" Margin="8,0,0,0" IsHitTestVisible="False"/>
                                </Grid>

                                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                                        <TextBlock Text="STARTING LEVEL:" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>
                                        <ComboBox x:Name="LevelSelector" Style="{StaticResource DarkComboBox}" Width="60" SelectedIndex="0" SelectionChanged="LevelSelector_SelectionChanged">
                                            <ComboBoxItem Content="1"/>
                                            <ComboBoxItem Content="2"/>
                                            <ComboBoxItem Content="3"/>
                                            <ComboBoxItem Content="4"/>
                                            <ComboBoxItem Content="5"/>
                                            <ComboBoxItem Content="6"/>
                                            <ComboBoxItem Content="7"/>
                                            <ComboBoxItem Content="8"/>
                                            <ComboBoxItem Content="9"/>
                                            <ComboBoxItem Content="10"/>
                                            <ComboBoxItem Content="11"/>
                                            <ComboBoxItem Content="12"/>
                                            <ComboBoxItem Content="13"/>
                                            <ComboBoxItem Content="14"/>
                                            <ComboBoxItem Content="15"/>
                                            <ComboBoxItem Content="16"/>
                                            <ComboBoxItem Content="17"/>
                                            <ComboBoxItem Content="18"/>
                                            <ComboBoxItem Content="19"/>
                                            <ComboBoxItem Content="20"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <CheckBox x:Name="HomebrewToggle" Content="Enable Homebrew Content" Foreground="Orange" VerticalAlignment="Center" Click="HomebrewToggle_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TabControl Grid.Row="1" x:Name="BuilderTabControl" Background="Transparent" BorderThickness="0">
                            <TabControl.ItemContainerStyle>
                                <Style TargetType="TabItem"><Setter Property="Visibility" Value="Collapsed"/></Style>
                            </TabControl.ItemContainerStyle>

                        <TabItem>
                            <Grid Margin="30">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,25">
                                    <TextBlock Text="Choose Your Lineage" Foreground="White" FontSize="32" FontWeight="Light"/>
                                    <TextBlock Text="(Double-click to select)" Foreground="Gray" FontSize="12" FontStyle="Italic"/>
                                </StackPanel>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="350"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    
                                    <Grid>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                        <TextBlock x:Name="RaceSelectionCount" Text="0/1 Selected" Foreground="Orange" HorizontalAlignment="Right" Margin="0,0,5,5" FontSize="11" FontWeight="Bold"/>

                                        <ListBox x:Name="RaceList" Grid.Row="1" Background="#252526" Foreground="White" SelectionChanged="RaceList_SelectionChanged" MouseDoubleClick="RaceList_MouseDoubleClick">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                                    <Setter Property="IsEnabled" Value="{Binding IsDisabled, Converter={StaticResource InverseBooleanConverter}}"/>
                                                    <Setter Property="Padding" Value="10,8"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="0,1">
                                                                    <ContentPresenter/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#333333"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter Property="Background" Value="#2D2D30"/>
                                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                                                        <Setter Property="BorderThickness" Value="1"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Opacity" Value="0.4"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}" Grid.Column="0" FontSize="14" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Source}" Grid.Column="1" Foreground="#666" FontSize="10" VerticalAlignment="Center" Margin="10,0"/>
                                                        <Button Grid.Column="2" Content="✕" Width="20" Height="20" Background="Transparent" Foreground="#FF6B6B" BorderThickness="0" 
                                                                Visibility="{Binding SelectedVisibility}" Click="UnlockRace_Click" ToolTip="Start Over" FontWeight="Bold"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>

                                    <Border Grid.Column="1" Margin="20,0,0,0" Background="#1E1E1E" Padding="25" CornerRadius="8">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <TextBlock x:Name="RaceDescription" TextWrapping="Wrap" Foreground="White" FontSize="15" Text="Select a race to see details..."/>
                                                
                                                <!-- Dynamic Selection Area -->
                                                <StackPanel x:Name="RaceOptionsPanel" Visibility="Collapsed" Margin="0,20,0,0">
                                                    <TextBlock Text="ABILITY SCORE BONUSES" Foreground="Orange" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                                                    <TextBlock Text="Select ability scores to increase by +1:" Foreground="Gray" FontSize="11" Margin="0,0,0,10" FontStyle="Italic"/>
                                                    <TextBlock Text="You can only choose 1 of each ability to increase" Foreground="Gray" FontSize="9" Margin="0,0,0,10" FontStyle="Italic"/>
                                                    <ItemsControl x:Name="ScoreSelectorsList">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,0,0,10">
                                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                                    <TextBlock Text="{Binding Label}" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                                    <ComboBox Width="120" Style="{StaticResource DarkComboBox}" ItemsSource="{Binding Options}" SelectedItem="{Binding SelectedOption, Mode=TwoWay}" SelectionChanged="ScoreSelection_Changed"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                                <Button Grid.Row="2" Content="Next: Choose Class →" HorizontalAlignment="Right" Width="220" Height="45" Background="{StaticResource AccentColor}" Foreground="White" FontWeight="Bold" Click="GoToClass_Click" Margin="0,20,0,0"/>
                            </Grid>
                        </TabItem>

                        <TabItem>
                            <Grid Margin="30">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,25">
                                    <TextBlock Text="Select Your Profession" Foreground="White" FontSize="32" FontWeight="Light"/>
                                    <TextBlock Text="(Double-click to select)" Foreground="Gray" FontSize="12" FontStyle="Italic"/>
                                </StackPanel>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="350"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

                                    <Grid>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                        <TextBlock x:Name="ClassSelectionCount" Text="0/1 Selected" Foreground="Orange" HorizontalAlignment="Right" Margin="0,0,5,5" FontSize="11" FontWeight="Bold"/>

                                        <ListBox x:Name="ClassList" Grid.Row="1" Background="#252526" Foreground="White" SelectionChanged="ClassList_SelectionChanged" MouseDoubleClick="ClassList_MouseDoubleClick">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                                    <Setter Property="IsEnabled" Value="{Binding IsDisabled, Converter={StaticResource InverseBooleanConverter}}"/>
                                                    <Setter Property="Padding" Value="10,8"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="0,1">
                                                                    <ContentPresenter/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#333333"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter Property="Background" Value="#2D2D30"/>
                                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                                                        <Setter Property="BorderThickness" Value="1"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Opacity" Value="0.4"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}" Grid.Column="0" FontSize="14" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Source}" Grid.Column="1" Foreground="#666" FontSize="10" VerticalAlignment="Center" Margin="10,0"/>
                                                        <Button Grid.Column="2" Content="✕" Width="20" Height="20" Background="Transparent" Foreground="#FF6B6B" BorderThickness="0" 
                                                                Visibility="{Binding SelectedVisibility}" Click="UnlockClass_Click" ToolTip="Start Over" FontWeight="Bold"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>

                                    <Border Grid.Column="1" Margin="20,0,0,0" Background="#1E1E1E" Padding="25" CornerRadius="8">
                                        <TextBlock x:Name="ClassDescription" TextWrapping="Wrap" Foreground="White" FontSize="15" Text="Select a class to see its abilities..."/>
                                    </Border>
                                </Grid>
                                <Button Grid.Row="2" Content="Next: Subclass Selection →" HorizontalAlignment="Right" Width="220" Height="45" Background="{StaticResource AccentColor}" Foreground="White" FontWeight="Bold" Click="GoToSubclass_Click" Margin="0,20,0,0"/>
                            </Grid>
                        </TabItem>

                        <TabItem>
                            <Grid Margin="30">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,25">
                                    <TextBlock Text="Select Your Archetype" Foreground="White" FontSize="32" FontWeight="Light"/>
                                    <TextBlock Text="(Double-click to select)" Foreground="Gray" FontSize="12" FontStyle="Italic"/>
                                </StackPanel>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="350"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

                                    <Grid>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                        <TextBlock x:Name="SubclassSelectionCount" Text="0/1 Selected" Foreground="Orange" HorizontalAlignment="Right" Margin="0,0,5,5" FontSize="11" FontWeight="Bold"/>

                                        <ListBox x:Name="SubclassList" Grid.Row="1" Background="#252526" Foreground="White" SelectionChanged="SubclassList_SelectionChanged" MouseDoubleClick="SubclassList_MouseDoubleClick">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                                    <Setter Property="IsEnabled" Value="{Binding IsDisabled, Converter={StaticResource InverseBooleanConverter}}"/>
                                                    <Setter Property="Padding" Value="10,8"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="0,1">
                                                                    <ContentPresenter/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#333333"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter Property="Background" Value="#2D2D30"/>
                                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                                                        <Setter Property="BorderThickness" Value="1"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Opacity" Value="0.4"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}" Grid.Column="0" FontSize="14" VerticalAlignment="Center"/>
                                                        <Button Grid.Column="2" Content="✕" Width="20" Height="20" Background="Transparent" Foreground="#FF6B6B" BorderThickness="0" 
                                                                Visibility="{Binding SelectedVisibility}" Click="UnlockSubclass_Click" ToolTip="Start Over" FontWeight="Bold"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>

                                    <Border Grid.Column="1" Margin="20,0,0,0" Background="#1E1E1E" Padding="25" CornerRadius="8">
                                        <TextBlock x:Name="SubclassDescription" TextWrapping="Wrap" Foreground="White" FontSize="15" Text="Select a subclass to see details..."/>
                                    </Border>
                                </Grid>
                                <Button Grid.Row="2" Content="Next: Ability Scores →" HorizontalAlignment="Right" Width="220" Height="45" Background="{StaticResource AccentColor}" Foreground="White" FontWeight="Bold" Click="GoToStats_Click" Margin="0,20,0,0"/>
                            </Grid>
                        </TabItem>

                        <TabItem>
                            <Grid Margin="30">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <Border Background="#252526" Padding="20" Margin="0,0,0,20" CornerRadius="4">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="PointsRemainingLabel" Text="27" Foreground="{StaticResource AccentColor}" FontSize="36" FontWeight="Bold"/>
                                            <TextBlock Text="POINTS REMAINING" Foreground="White" VerticalAlignment="Center" Margin="15,0,0,0" FontSize="14" Opacity="0.7"/>
                                        </StackPanel>
                                        <TextBlock Text="For each 2 points over level 3 remaining, you get to choose a feat in exchange for 2 points." Foreground="#888" FontSize="11" Margin="5,5,0,0" FontStyle="Italic"/>
                                        <TextBlock Text="Values in green include racial bonuses." Foreground="LightGreen" FontSize="11" Margin="5,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <UniformGrid Grid.Row="1" Columns="3" Rows="2">
                                    <Border Style="{StaticResource StatCard}"><StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="STRENGTH" HorizontalAlignment="Center" Foreground="Orange" FontSize="11" FontWeight="Bold"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock x:Name="StrValue" Text="8" FontSize="42" Foreground="White" FontWeight="Bold"/>
                                            <TextBlock x:Name="StrBonus" Text="+0" FontSize="18" Foreground="LightGreen" FontWeight="Bold" VerticalAlignment="Top" Margin="2,5,0,0"/>
                                        </StackPanel>
                                        <TextBlock x:Name="StrMod" Text="-1" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                            <Button Content="-" Style="{StaticResource FlatDarkButton}" Width="40" Height="30" Click="StatDown_Click" Tag="STR"/>
                                            <Button Content="+" Style="{StaticResource FlatDarkButton}" Width="40" Height="30" Click="StatUp_Click" Tag="STR" Margin="5,0,0,0"/>
                                        </StackPanel></StackPanel></Border>
                                    <Border Style="{StaticResource StatCard}"><StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="DEXTERITY" HorizontalAlignment="Center" Foreground="SkyBlue" FontSize="11" FontWeight="Bold"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock x:Name="DexValue" Text="8" FontSize="42" Foreground="White" FontWeight="Bold"/>
                                            <TextBlock x:Name="DexBonus" Text="+0" FontSize="18" Foreground="LightGreen" FontWeight="Bold" VerticalAlignment="Top" Margin="2,5,0,0"/>
                                        </StackPanel>
                                        <TextBlock x:Name="DexMod" Text="-1" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                            <Button Content="-" Style="{StaticResource FlatDarkButton}" Width="40" Height="30" Click="StatDown_Click" Tag="DEX"/>
                                            <Button Content="+" Style="{StaticResource FlatDarkButton}" Width="40" Height="30" Click="StatUp_Click" Tag="DEX" Margin="5,0,0,0"/>
                                        </StackPanel></StackPanel></Border>
                                    <Border Style="{StaticResource StatCard}"><StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="CONSTITUTION" HorizontalAlignment="Center" Foreground="LightGreen" FontSize="11" FontWeight="Bold"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock x:Name="ConValue" Text="8" FontSize="42" Foreground="White" FontWeight="Bold"/>
                                            <TextBlock x:Name="ConBonus" Text="+0" FontSize="18" Foreground="LightGreen" FontWeight="Bold" VerticalAlignment="Top" Margin="2,5,0,0"/>
                                        </StackPanel>
                                        <TextBlock x:Name="ConMod" Text="-1" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                            <Button Content="-" Style="{StaticResource FlatDarkButton}" Width="40" Height="30" Click="StatDown_Click" Tag="CON"/>
                                            <Button Content="+" Style="{StaticResource FlatDarkButton}" Width="40" Height="30" Click="StatUp_Click" Tag="CON" Margin="5,0,0,0"/>
                                        </StackPanel></StackPanel></Border>
                                    <Border Style="{StaticResource StatCard}"><StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="INTELLIGENCE" HorizontalAlignment="Center" Foreground="MediumPurple" FontSize="11" FontWeight="Bold"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock x:Name="IntValue" Text="8" FontSize="42" Foreground="White" FontWeight="Bold"/>
                                            <TextBlock x:Name="IntBonus" Text="+0" FontSize="18" Foreground="LightGreen" FontWeight="Bold" VerticalAlignment="Top" Margin="2,5,0,0"/>
                                        </StackPanel>
                                        <TextBlock x:Name="IntMod" Text="-1" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                            <Button Content="-" Style="{StaticResource FlatDarkButton}" Width="40" Height="30" Click="StatDown_Click" Tag="INT"/>
                                            <Button Content="+" Style="{StaticResource FlatDarkButton}" Width="40" Height="30" Click="StatUp_Click" Tag="INT" Margin="5,0,0,0"/>
                                        </StackPanel></StackPanel></Border>
                                    <Border Style="{StaticResource StatCard}"><StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="WISDOM" HorizontalAlignment="Center" Foreground="Gold" FontSize="11" FontWeight="Bold"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock x:Name="WisValue" Text="8" FontSize="42" Foreground="White" FontWeight="Bold"/>
                                            <TextBlock x:Name="WisBonus" Text="+0" FontSize="18" Foreground="LightGreen" FontWeight="Bold" VerticalAlignment="Top" Margin="2,5,0,0"/>
                                        </StackPanel>
                                        <TextBlock x:Name="WisMod" Text="-1" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                            <Button Content="-" Style="{StaticResource FlatDarkButton}" Width="40" Height="30" Click="StatDown_Click" Tag="WIS"/>
                                            <Button Content="+" Style="{StaticResource FlatDarkButton}" Width="40" Height="30" Click="StatUp_Click" Tag="WIS" Margin="5,0,0,0"/>
                                        </StackPanel></StackPanel></Border>
                                    <Border Style="{StaticResource StatCard}"><StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="CHARISMA" HorizontalAlignment="Center" Foreground="LightPink" FontSize="11" FontWeight="Bold"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock x:Name="ChaValue" Text="8" FontSize="42" Foreground="White" FontWeight="Bold"/>
                                            <TextBlock x:Name="ChaBonus" Text="+0" FontSize="18" Foreground="LightGreen" FontWeight="Bold" VerticalAlignment="Top" Margin="2,5,0,0"/>
                                        </StackPanel>
                                        <TextBlock x:Name="ChaMod" Text="-1" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                            <Button Content="-" Style="{StaticResource FlatDarkButton}" Width="40" Height="30" Click="StatDown_Click" Tag="CHA"/>
                                            <Button Content="+" Style="{StaticResource FlatDarkButton}" Width="40" Height="30" Click="StatUp_Click" Tag="CHA" Margin="5,0,0,0"/>
                                        </StackPanel></StackPanel></Border>
                                </UniformGrid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                   </Grid>  <!-- Closing the Grid.Column="1" container -->
                </Grid>     <!-- Closing the main Grid of the TabItem -->
            </TabItem>
        </TabControl>

        <Grid x:Name="OverlayBlur" Visibility="Collapsed" Background="#CC000000">
            <Border Background="#1E1E1E" CornerRadius="12" BorderBrush="#444" BorderThickness="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="450">
                <Grid>
                    <StackPanel Margin="30">
                        <TextBlock x:Name="OverlayTitle" Text="Title" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock x:Name="OverlayMessage" Text="Message" Foreground="#AAA" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,25"/>
                        <TextBox x:Name="OverlayInput" Background="#2D2D30" Foreground="White" BorderBrush="#555" Padding="12" Margin="0,0,0,20" Visibility="Collapsed" FontSize="16"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Button x:Name="OverlayAltBtn" Content="SIMPLE PRESET" Click="SimplePreset_Click" Height="40" Width="130" Background="#333" Foreground="White" Visibility="Collapsed"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="OverlayConfirmBtn" Content="CONFIRM" Click="ConfirmOverlay_Click" Width="120" Height="40" Background="{StaticResource AccentColor}" Foreground="White"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                    <Button Content="✕" Click="CloseOverlay_Click" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" 
                            Width="30" Height="30" Background="Transparent" Foreground="Gray" BorderThickness="0" FontSize="16" FontWeight="Bold"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>