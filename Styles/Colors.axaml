<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="bg.color">#121212</Color>
    <Color x:Key="bg.alt.color">#1E1E1E</Color>
    <Color x:Key="accent.color">#007acc</Color>
    <Color x:Key="text.primary">#FFFFFF</Color>
    <Color x:Key= "text.secondary">#AAAAAA</Color>

    <SolidColorBrush x:Key="bg.brush" Color="{StaticResource bg.color}" />
    <SolidColorBrush x:Key="bg.alt.brush" Color="{StaticResource bg.alt.color}" />
    <SolidColorBrush x:Key="accent.brush" Color="{StaticResource accent.color}" />
    <SolidColorBrush x:Key="text.brush" Color="{StaticResource text.primary}" />
    <SolidColorBrush x:Key="text.secondary.brush" Color="{StaticResource text.secondary}" />


  <!-- Aliases for compatibility -->
  <StaticResource x:Key="Brush.Background" ResourceKey="bg.brush" />
  <StaticResource x:Key="Brush.Accent" ResourceKey="accent.brush" />
</ResourceDictionary>

